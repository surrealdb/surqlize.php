{
    "name": "surqlize/surqlize",
    "description": "SurrealDB ORM for PHP — attribute-driven models, edges, and query builder.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": ">=8.4",
        "surrealdb/surrealdb.php": "@dev"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "Surqlize\\": "src/",
            "Surqlize\\Examples\\": "examples/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Surqlize\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/surqlize"
    ],
    "repositories": [
        {
            "type": "path",
            "url": "../surrealdb.php-refined"
        }
    ],
    "minimum-stability": "dev",
    "prefer-stable": true,
    "config": {
        "sort-packages": true
    },
    "scripts": {
        "test": "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse --memory-limit=512M",
        "memory": "bin/surqlize memory:footprint"
    }
}
